@font-face
  font-family: "Sour Gummy"
  src: url("/font/SourGummy-VariableFont_wdth,wght.ttf") format("truetype")
  font-weight: 400
  font-style: normal
  font-display: swap

@font-face
  font-family: "Imperial Script"
  src: url("/font/ImperialScript-Regular.ttf") format("truetype")
  font-weight: 400
  font-style: normal
  font-display: swap

@font-face
  font-family: "ComicNeue-Bold"
  src: url("/font/ComicNeue-BoldItalic.ttf") format("truetype")
  font-weight: 700
  font-style: italic
  font-display: swap
@font-face
  font-family: "ComicNeue-Light"
  src: url("/font/ComicNeue-LightItalic.ttf") format("truetype")
  font-weight: 700
  font-style: italic
  font-display: swap
@font-face
  font-family: "ComicNeue-Normal"
  src: url("/font/ComicNeue-Bold.ttf") format("truetype")
  font-weight: 700
  font-style: normal
  font-display: swap
#sidebar .overview .author
  .name
    font-family: "ComicNeue-Light", "STKaiti", "KaiTi", cursive
    font-style: italic
    font-weight: 700
    font-size: 140%
  .description
    font-family: "Imperial Script", "STKaiti", "KaiTi", cursive
    font-style: normal
    font-size: 170%

.md :not(pre) > code
  background-color: rgba(233, 200, 221, .3)
  color: #d84a4a
  padding: .15em .4em
  border-radius: .35em

.kmp-string-diagram
  display: inline-grid
  gap: .55rem
  font-family: $font-family-monospace
  font-size: 1.125rem
  line-height: 1.5
  color: rgba(255, 255, 255, .72)

.kmp-string-row
  display: inline-grid
  grid-auto-flow: column
  grid-auto-columns: 1ch
  align-items: center
  justify-items: center

.kmp-string-row--boxed
  padding: .35rem .45rem
  border: 2px solid #4CAF50
  border-radius: .4rem
  background-color: #e8f5e9
  color: #9fa4a8

.kmp-string-cell
  width: 1ch
  text-align: center

.kmp-string-cell--hit
  background-color: #e3f2fd
  box-shadow: inset 0 0 0 1px #2196F3
  border-radius: .18rem

.kmp-string-spacer
  width: 1ch
